[0.020, "o", "\u001b[?2026h\r\u001b[2C\u001b[1A\u001b[38;5;153m/dream                  Memory consolidation - review recent sessions, merge/prune/up…\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246m/statusline\u001b[13CSet\u001b[1Cup\u001b[1CClaude\u001b[1CCode's\u001b[1Cstatus\u001b[1Cline\u001b[1CUI\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246m/debug\u001b[18CEnable\u001b[1Cdebug\u001b[1Clogging\u001b[1Cfor\u001b[1Cthis\u001b[1Csession\u001b[1Cand\u001b[1Chelp\u001b[1Cdiagnose\u001b[1Cissue…\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246m/add-dir\u001b[16CAdd\u001b[1Ca\u001b[1Cnew\u001b[1Cworking\u001b[1Cdirectory\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246m/agents\u001b[17CManage\u001b[1Cagent\u001b[1Cconfigurations\u001b[39m\r\r\n\u001b[2C\u001b[38;5;246m/branch\u001b[17CCreate\u001b[1Ca\u001b[1Cbranch\u001b[1Cof\u001b[1Cthe\u001b[1Ccurrent\u001b[1Cconversation\u001b[1Cat\u001b[1Cthis\u001b[1Cpoint\u001b[39m\r\r\n\u001b[?2026l"]
[0.156, "o", "\u001b[?2026h\r\u001b[3C\u001b[8Ae\u001b[7m \u001b[27m\r\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\u001b[?2026l"]
[0.021, "o", "\u001b[?2026h\r\u001b[3C\u001b[6A\u001b[38;5;153mexit \u001b[18CExit the REPL\u001b[39m                                                 \r\u001b[3C\u001b[1B\u001b[38;5;246meffort    \u001b[17Ceffort l\u001b[1Cvel for\u001b[1Cmodel usag\u001b[1C\u001b[39m   \r\u001b[3C\u001b[1B\u001b[38;5;246mexport\u001b[18Cxport\u001b[1Cthe current conversation to a file\u001b[1Cor clipboard\u001b[39m        \r\u001b[3C\u001b[1B\u001b[38;5;246mextra-usage\u001b[12CConfigure\u001b[1Cextra usage to keep working when limits are hit\r\u001b[3C\u001b[1Bdr\u001b[1Cam \u001b[18Cemory\u001b[1Cconsolidat\u001b[1Con - review recent sessions, merge/prune/up…\r\u001b[3C\u001b[1Bst\u001b[1Ctusline\u001b[13CSet up\u001b[1CClaude Code's status line UI\u001b[39m                      \r\r\n\u001b[?2026l"]
