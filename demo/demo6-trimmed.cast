[0.037, "o", "\u001b[?2026h\u001b[2J\u001b[3J\u001b[H\u001b[38;5;174m▗\u001b[48;5;174m\u001b[38;5;16m ▗   ▖ \u001b[49m\u001b[38;5;174m▖\u001b[2C\u001b[39m\u001b[1mClaude\u001b[1CCode\u001b[1C\u001b[22m\u001b[38;5;246mv2.1.81\u001b[39m\r\r\n\u001b[1C\u001b[48;5;174m       \u001b[3C\u001b[49m\u001b[38;5;246mOpus\u001b[1C4.6\u001b[1C(1M\u001b[1Ccontext)\u001b[1Cwith\u001b[1Chigh\u001b[1Ceffort\u001b[1C·\u001b[1CClaude\u001b[1CTeam\u001b[39m\r\r\n\u001b[2C\u001b[38;5;174m▘▘\u001b[1C▝▝\u001b[4C\u001b[38;5;246m~/Code/personal/dream\u001b[39m\r\r\n\r\r\n\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mset me up\u001b[39m                                                                               \u001b[49m\r\r\n\r\r\n\u001b[38;5;114m⏺\u001b[1C\u001b[39m\u001b[1mBash\u001b[22m(./install.sh)\r\r\n\u001b[38;5;246m \u001b[1C⎿\u001b[1C \u001b[34mdream\u001b[1Cinstaller\u001b[1C\u001b[39mv0.1.0\r\r\n\u001b[5C======================\r\r\n\u001b[5C\u001b[2m…\u001b[1C+9\u001b[1Clines\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[22m\r\r\n\r\r\n\u001b[2C\u001b[38;5;246mRead\u001b[1C\u001b[1m1\u001b[22m file\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[39m\r\r\n\r\r\n\u001b[38;5;231m⏺\u001b[1C\u001b[39mInstalled.\u001b[1C\u001b[38;5;153m/dream\u001b[1C\u001b[39mis\u001b[1Cnow\u001b[1Cavailable\u001b[1Cin\u001b[1Cevery\u001b[1CClaude\u001b[1CCode\u001b[1Csession.\r\r\n\r\r\n\u001b[38;5;244m──────────────────────────────"]
[0.000, "o", "────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;5;244m──────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\n\u001b[2C\u001b[38;5;211m⏵⏵\u001b[1Cbypass\u001b[1Cpermissions\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1C…\u001b[1C\u001b[38;5;220mUpdate\u001b[1Cavailable!\u001b[1CRun:\u001b[1C\u001b[1mbrew\u001b[1Cupgrad…\u001b[22m\u001b[39m\r\r\n\u001b[?2026l"]
